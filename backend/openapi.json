    "/api/v1/transactions": {
      "get": {
        "tags": ["Transactions"],
        "summary": "List transactions",
        "description": "Returns inventory movements with optional filtering. Results are ordered by date descending.",
        "operationId": "listTransactions",
        "parameters": [
          { "name": "type",      "in": "query", "description": "Filter by transaction type.", "schema": { "type": "string", "enum": ["purchase", "sale", "return", "adjustment", "issue"] } },
          { "name": "productId", "in": "query", "description": "Filter by product UUID.",     "schema": { "type": "string", "format": "uuid" } },
          { "name": "limit",     "in": "query", "description": "Maximum records to return (default: 100).", "schema": { "type": "integer", "minimum": 1, "maximum": 500 } }
        ],
        "responses": {
          "200": { "description": "Transaction list.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiSuccess" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "tags": ["Transactions"],
        "summary": "Create transaction",
        "description": "Record a single inventory movement. For multi-line job orders, prefer the batch endpoint.",
        "operationId": "createTransaction",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/TransactionLine" } }
          }
        },
        "responses": {
          "201": { "description": "Transaction recorded.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiSuccess" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "422": { "$ref": "#/components/responses/UnprocessableEntity" }
        }
      }
    },
    "/api/v1/transactions/batch": {
      "post": {
        "tags": ["Transactions"],
        "summary": "Batch create transactions",
        "description": "Atomically record up to 50 inventory movements in a single request. All lines share the same audit timestamp. If any line fails validation, the entire batch is rejected. Use a shared `referenceId` across all lines to enable group revert via `DELETE /transactions/group/{referenceId}`.",
        "operationId": "batchCreateTransactions",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/TransactionBatchBody" } }
          }
        },
        "responses": {
          "201": { "description": "All transactions recorded.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiSuccess" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "422": { "$ref": "#/components/responses/UnprocessableEntity" }
        }
      }
    },
    "/api/v1/transactions/group/{referenceId}": {
      "delete": {
        "tags": ["Transactions"],
        "summary": "Revert transaction group",
        "description": "Reverses all transactions sharing the given `referenceId` by posting compensating entries (opposite quantity, same product). Useful for rolling back a complete job-order issuance.",
        "operationId": "revertTransactionGroup",
        "parameters": [
          { "name": "referenceId", "in": "path", "required": true, "description": "The group reference ID used during batch creation.", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Group reverted.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiSuccess" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
